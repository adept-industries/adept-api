# Local PostgreSQL database name, login, password, and published host port.
POSTGRES_HOST=localhost
POSTGRES_DB=adept
POSTGRES_USER=adept
POSTGRES_PASSWORD=change_me_local_only
POSTGRES_PORT=5432

# API authentication/encryption secrets. Generate a different random value for
# each blank entry; never reuse one value for several purposes.
APP_JWT_SECRET_BASE64=
APP_TOKEN_HASH_PEPPER_BASE64=
APP_INTEGRATION_ENCRYPTION_KEY_V1_BASE64=
APP_INTEGRATION_ENCRYPTION_ACTIVE_KEY_VERSION=1
APP_INTERNAL_ENGINE_TOKEN=
# Local HTTP does not use secure cookies. Production HTTPS must set this true.
APP_COOKIE_SECURE=false

# Optional local connection-pool tuning; the shown values match application.yml.
DB_MAX_POOL_SIZE=10
DB_MIN_IDLE=2
# Opt in only when the local-only DataSeeder exists and sample rows are wanted.
APP_SEED_LOCAL=false

# Values created when registering the GitHub App.
GITHUB_INTEGRATION_ENABLED=false
GITHUB_APP_ID=
GITHUB_APP_SLUG=
GITHUB_APP_PRIVATE_KEY_BASE64=
GITHUB_WEBHOOK_SECRET=

# Values created in the Atlassian developer console.
JIRA_INTEGRATION_ENABLED=false
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
# Jira calls the API directly; the API redirects the browser to frontend-base-url.
JIRA_CALLBACK_URL=http://localhost:8080/api/v1/integrations/jira/callback

# Mailpit needs no username/password locally; a production SMTP provider may.
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
SPRING_MAIL_AUTH=false
SPRING_MAIL_STARTTLS=false

# The Python worker uses these SMTP names. Compose overrides host/port to mailpit.
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
APP_EMAIL_FROM="Adept Local <no-reply@adept.local>"

# Browser/API locations for hybrid development. Compose overrides the frontend
# URL to port 3000 for the fully containerized stack.
APP_FRONTEND_BASE_URL=http://localhost:5173
APP_PUBLIC_API_BASE_URL=http://localhost:8080
APP_ENGINE_BASE_URL=http://localhost:8000

# Worker polling/retry settings and in-container paths to model artifacts.
ENGINE_POLL_INTERVAL_MS=1000
ENGINE_WORKER_ID=local-worker-1
ENGINE_MAX_JOB_ATTEMPTS=8
RISK_MODEL_PATH=/app/app/risk/artifacts/model.joblib
RISK_VECTORIZER_PATH=/app/app/risk/artifacts/vectorizer.joblib

